# Clase Nodo
class Nodo:
	def __init__(self, data):
		self.data = data
		self.siguiente = None

class ListaNombres:
	def __init__(self):
		self.cabeza = None
		
  # Agregar al inicio
	def agregarInicioNombre(self, data):
		nuevo_nodo = Nodo(data)
		if self.cabeza is None:
			self.cabeza = nuevo_nodo
			return
		else:
			nuevo_nodo.siguiente = self.cabeza

			self.cabeza = nuevo_nodo
		
